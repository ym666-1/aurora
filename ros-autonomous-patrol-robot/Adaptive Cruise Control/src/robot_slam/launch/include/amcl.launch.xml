<launch>

  <arg name="use_map_topic" default="false"/>
  <arg name="scan_topic" default="/scan_filtered"/>

  <node pkg="amcl"
        type="amcl"
        name="amcl"
        clear_params="true"
        output="screen">

    <!-- 坐标系 -->
    <param name="global_frame_id" value="map"/>
    <param name="odom_frame_id" value="odom"/>
    <param name="base_frame_id" value="base_footprint"/>

    <!-- 地图来源：map_server 的 static_map 服务 -->
    <param name="use_map_topic" value="$(arg use_map_topic)"/>

    <!-- 不要启动就全局撒粒子；用 RViz 2D Pose Estimate 给初始位姿 -->
    <param name="use_global_localization" value="false"/>
    <param name="global_localization" value="false"/>

    <!-- 全向底盘模型 -->
    <param name="odom_model_type" value="omni"/>

    <!-- wheel_odom 直接做 odom TF，横移有一定误差，参数不要太小 -->
    <param name="odom_alpha1" value="0.15"/>
    <param name="odom_alpha2" value="0.15"/>
    <param name="odom_alpha3" value="0.15"/>
    <param name="odom_alpha4" value="0.15"/>
    <param name="odom_alpha5" value="0.10"/>

    <!-- 粒子数：3.6m 小场地不需要 5000，先稳一点 -->
    <param name="min_particles" value="500"/>
    <param name="max_particles" value="2000"/>
    <param name="kld_err" value="0.02"/>
    <param name="kld_z" value="0.99"/>
    <param name="resample_interval" value="1"/>

    <!-- 恢复参数 -->
    <param name="recovery_alpha_slow" value="0.001"/>
    <param name="recovery_alpha_fast" value="0.1"/>

    <!-- 可视化 -->
    <param name="gui_publish_rate" value="10.0"/>

    <!-- 激光参数：你的场地 3.6m，过滤后雷达最大 3.5m -->
    <param name="laser_max_beams" value="80"/>
    <param name="laser_min_range" value="0.15"/>
    <param name="laser_max_range" value="3.5"/>

    <!-- likelihood_field 适合静态地图定位 -->
    <param name="laser_model_type" value="likelihood_field"/>
    <param name="laser_likelihood_max_dist" value="0.8"/>

    <param name="laser_z_hit" value="0.7"/>
    <param name="laser_z_short" value="0.05"/>
    <param name="laser_z_max" value="0.05"/>
    <param name="laser_z_rand" value="0.2"/>
    <param name="laser_sigma_hit" value="0.12"/>
    <param name="laser_lambda_short" value="0.1"/>

    <!-- 小场地，定位更新要比原来更及时 -->
    <param name="update_min_d" value="0.08"/>
    <param name="update_min_a" value="0.10"/>

    <param name="transform_tolerance" value="0.5"/>

    <remap from="scan" to="$(arg scan_topic)"/>
  </node>

</launch>

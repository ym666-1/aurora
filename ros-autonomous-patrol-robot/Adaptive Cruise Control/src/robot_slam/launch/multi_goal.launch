<launch>
  <node name="navigation_node" pkg="robot_slam" type="main.py" output="screen">
    
    <!-- 使用 rosparam 传递真正的列表类型 -->
    <rosparam param="goalListX">[0, 1.224, 1.130, 1.210, 1.650, 1.659, 1.625, 2.005, 2.055, 1.987, 0.158, 1.645, 3.050, 1.640, 2.843, 0.521, 0.250]</rosparam>
    
    <rosparam param="goalListY">[0, 1.270, 1.690, 2.080, 1.220, 1.685, 2.097, 1.299, 1.650, 2.112, 1.664, 3.100, 1.630, 0.130, 1.656, 3.250, 3.270]</rosparam>
    
    <rosparam param="goalListYaw">[0,90, 90, 90, 90, 90, 90, 90, 90, 90, 182, 92, -3, -92, 180, 0, -1]</rosparam>

    <param name="go_transition_before_tasks" value="false"/>

    <param name="go_transition_after_detection" value="true"/>

  </node>
</launch>
